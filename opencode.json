{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-plugin-preload-skills"
  ],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "permission": {
    "skill": {
      "official-document-writing": "allow",
      "doc-*": "allow",
      "skill-creator": "ask",
